generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Household {
  id        Int           @id @default(autoincrement())
  name      String
  users     User[]
  categories Category[]
  transactions Transaction[]
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  householdId  Int
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model Category {
  id            Int           @id @default(autoincrement())
  householdId   Int
  name          String
  monthlyBudget Float         @default(0)
  isDefault     Boolean       @default(false)
  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
}

enum PaymentMethod {
  Cash
  DebitCard
  CreditCard
  DirectDebit
  StandingOrder
  BankTransfer
}

model Transaction {
  id            Int           @id @default(autoincrement())
  householdId   Int
  categoryId    Int
  date          DateTime
  description   String
  amount        Int
  paymentMethod PaymentMethod
  notes         String?
  createdBy     Int
  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}
